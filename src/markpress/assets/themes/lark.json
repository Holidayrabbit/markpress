{
    "meta": {
        "name": "Modern Engineering Standard Lark (Print Optimized)",
        "version": "1.1",
        "author": "MarkPress Team"
    },
    "page": {
        "size": "A4",
        "orientation": "portrait",
        "margin_top": 25,
        "margin_bottom": 25,
        "margin_left": 25,
        "margin_right": 25,
        "background_color": "#FFFFFF"
    },
    "fonts": {
        "regular": "WenYuanSansSC",
        "bold": "WenYuanSansSC-Bold",
        "heading": "WenYuanSansSC-Bold",
        "code": "JetBrainsMono"
    },
    "colors": {
        "text_primary": "#1f2329",
        "text_secondary": "#5c6066",
        "link": "#3370ff",
        "border": "#dee0e3"
    },
    "styles": {
        "body": {
            "font_size": 10.5,
            "leading": 17,
            "alignment": "LEFT",
            "space_after": 8
        },
        "headings": {
            "h1": {
                "font_size": 20,
                "leading": 28,
                "color": "#1f2329",
                "space_before": 20,
                "space_after": 12,
                "align": "LEFT"
            },
            "h2": {
                "font_size": 16,
                "leading": 24,
                "color": "#1f2329",
                "space_before": 16,
                "space_after": 10,
                "align": "LEFT"
            },
            "h3": {
                "font_size": 14,
                "leading": 21,
                "color": "#1f2329",
                "space_before": 14,
                "space_after": 8,
                "align": "LEFT"
            },
            "h4": {
                "font_size": 12,
                "leading": 18,
                "color": "#1f2329",
                "space_before": 12,
                "space_after": 8,
                "align": "LEFT"
            }
        },
        "code": {
            "style_name": "prism-default",
            "font_size": 9,
            "background_color": "#f5f6f7",
            "border_color": "#dee0e3",
            "show_line_numbers": false,
            "highlight_colors": {
                "Keyword": "#0077aa",
                "Name.Function": "#DD4A68",
                "Name.Class": "#DD4A68",
                "String": "#669900",
                "Comment": "#708090",
                "Number": "#990055",
                "Operator": "#9a6e3a",
                "Text": "#000000"
            }
        },
        "table": {
            "header_bg": "#f5f6f7",
            "header_text": "#1f2329",
            "row_bg_even": "#FFFFFF",
            "row_bg_odd": "#fcfcfc",
            "grid_color": "#dee0e3"
        },
        "quote": {
            "border_color": "#3370ff",
            "border_width": 2,
            "left_indent": 14,
            "text_color": "#5c6066"
        }
    }
}